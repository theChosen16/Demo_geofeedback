# ============================================================================
# Variables de Entorno - API GeoFeedback Papudo
# ============================================================================
# 
# USO:
# - Desarrollo local: Copiar a .env y configurar valores
# - Railway: Configurar en Dashboard → Service → Variables
#
# NOTA: Railway provee DATABASE_URL automáticamente cuando conectas PostgreSQL
# ============================================================================

# -----------------------------------------------------------------------------
# FLASK CONFIGURATION
# -----------------------------------------------------------------------------
FLASK_ENV=production
FLASK_DEBUG=False

# CRÍTICO: Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-CHANGE-IN-PRODUCTION

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Opción 1: DATABASE_URL (preferido - Railway lo provee automáticamente)
# DATABASE_URL=postgresql://user:password@host:port/database

# Opción 2: Variables individuales (solo para desarrollo local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geofeedback_papudo
DB_USER=geofeedback
DB_PASSWORD=your-password-here

# -----------------------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------------------
# La variable operativa leída por app.py es ALLOWED_ORIGINS (lista separada por comas).
# CORS_ORIGINS es un alias legado (también reconocido como fallback para compatibilidad).
# Si se deja vacío o sin definir, CORS queda completamente ABIERTO — solo
# aceptable en desarrollo local. En producción, define los orígenes exactos.
# Desarrollo: (dejar vacío)
# Producción: ALLOWED_ORIGINS=https://geofeedback.cl,https://www.geofeedback.cl
ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------------------
API_TITLE=GeoFeedback Papudo API
API_VERSION=1.0.0
API_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION (Gunicorn)
# -----------------------------------------------------------------------------
# IMPORTANTE: Para Railway free tier (512MB), máximo 2 workers
WORKERS=2
THREADS=2
TIMEOUT=120

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Opciones: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# OBSERVABILITY
# -----------------------------------------------------------------------------
# Secreto compartido que protege el desglose detallado de /api/v1/observability.
# Sin él, el endpoint solo expone status + public_stats a cualquiera (fail-safe).
# Los monitores internos deben enviarlo en el header X-Observability-Token.
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
# OBSERVABILITY_TOKEN=your-observability-token-here

# -----------------------------------------------------------------------------
# RAILWAY PROVEE AUTOMÁTICAMENTE (NO configurar manualmente)
# -----------------------------------------------------------------------------
# PORT - Puerto asignado dinámicamente
# RAILWAY_ENVIRONMENT - production/staging
# RAILWAY_SERVICE_NAME - Nombre del servicio
# RAILWAY_PUBLIC_DOMAIN - Dominio público asignado
