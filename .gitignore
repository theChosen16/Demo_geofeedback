# Python Caches & Compiled Files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml
.coverage.*

# Virtual Environments
venv/
.venv/
.venv_win/
env/
ENV/

# Node & Frontend Build Artifacts
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/dist/
frontend/.turbo/
.turbo/
.npm/

# IDEs, Editors & AI tools
.vscode/
.idea/
.claude/
.windsurfrules
.windsurf/
.agents/ui_reports/
.gemini/

# Data files (large rasters and raw data)
data/raw/*.tif
data/raw/*.shp
data/raw/*.shx
data/raw/*.dbf
data/raw/*.prj
data/raw/*.cpg

# Processed rasters (can be regenerated with scripts)
data/processed/*.tif

# Keep small processed data files and infrastructure
!data/processed/*.csv
!data/processed/*.json
!data/processed/*.geojson
!data/processed/*.png
!data/processed/*.pdf
!data/infrastructure/

# OS Junk
.DS_Store
Thumbs.db

# Logs & Temporary Files
*.log
*.tmp
*.temp

# Credentials & Secrets
.env
.env.local
service-account-key.json
api/service-account-key.json

# Git backup bundles (local backups, never commit)
backup_full_*.bundle
*.bundle

# Generated reports & PDF exports
*.pdf
!docs/references/*.pdf
