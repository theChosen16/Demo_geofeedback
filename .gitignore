# Data files (large rasters and raw data)
data/raw/*.tif
data/raw/*.shp
data/raw/*.shx
data/raw/*.dbf
data/raw/*.prj
data/raw/*.cpg

# Processed rasters (can be regenerated with scripts)
data/processed/*.tif

# Keep small processed data files and infrastructure
!data/processed/*.csv
!data/processed/*.json
!data/processed/*.geojson
!data/processed/*.png
!data/infrastructure/

# OS Junk
.DS_Store
Thumbs.db

# Logs & Temporary Files
*.log
*.tmp
*.temp
*.bak
*.swp

# Credentials & Secrets (Sensitive Development Info)
.env
.env.*
!.env.example
!backend/.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.p8
*.keystore
service-account-key.json
*service-account*.json
*.credentials
*.db
*.sqlite
*.sqlite3

# Git backup bundles (local backups, never commit)
backup_full_*.bundle
*.bundle

# Documentation & Internal Reports (Only README.md remains public)
docs/
SECURITY.md
SECURITY_AUDIT.md
DOCS.md
*.pdf
*.docx
*.doc
*.pptx
